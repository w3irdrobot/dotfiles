# shellcheck shell=bash

set -e

if [ -f ~/.bashrc ]; then
    # shellcheck source=./.bashrc
    source "$HOME/.bashrc"
fi

{{ if eq .chezmoi.os "linux" -}}
# Start Hyprland via uwsm if available
if command -v uwsm &> /dev/null && uwsm check may-start; then
    exec uwsm start hyprland.desktop
fi
{{ end -}}
