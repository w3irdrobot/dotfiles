# shellcheck shell=bash
#
# Custom PS1 prompt with Dracula colors
# Displays: directory | git branch/status | AWS profile | gcloud project | k8s context (if KUBECONFIG set)
# Two-line prompt with ₿ character (green=success, red=error)

# Color palette (using true color)
__prompt_green='\[\e[38;2;80;250;123m\]'
__prompt_pink='\[\e[38;2;255;121;198m\]'
__prompt_red='\[\e[38;2;255;85;85m\]'
__prompt_purple='\[\e[38;2;189;147;249m\]'
__prompt_blue='\[\e[38;2;139;233;253m\]'
__prompt_orange='\[\e[38;2;247;147;26m\]'   # Bitcoin orange (#F7931A)
__prompt_mustard='\[\e[38;2;225;219;88m\]'   # Classic mustard (#FFDB58)
__prompt_reset='\[\e[0m\]'

# Directory display:
#   - In a git repo: repo name + path from repo root (no truncation)
#   - In home (no repo): ~/path, truncated to ~/.../<last-2>/<last> if >3 components
#   - Outside home (no repo): full absolute path
__prompt_dir() {
    local dir="$PWD"
    local git_root
    git_root=$(git rev-parse --show-toplevel 2>/dev/null)

    if [[ -n "$git_root" ]]; then
        local repo_name
        repo_name=$(basename "$git_root")
        if [[ "$dir" == "$git_root" ]]; then
            echo "$repo_name"
        else
            echo "$repo_name${dir#$git_root}"
        fi
    elif [[ "$dir" == "$HOME"* ]]; then
        dir="${dir/#$HOME/\~}"
        local parts
        IFS='/' read -ra parts <<< "$dir"
        if (( ${#parts[@]} > 3 )); then
            echo "~/.../${parts[-2]}/${parts[-1]}"
        else
            echo "$dir"
        fi
    else
        echo "$dir"
    fi
}

# Git info: branch + dirty/clean
__prompt_git() {
    local branch
    branch=$(git symbolic-ref --short HEAD 2>/dev/null) || return
    local status="✓"
    git diff --quiet 2>/dev/null || status="✗"
    git diff --cached --quiet 2>/dev/null || status="✗"
    echo "  ${branch} ${status}"
}

# AWS profile (AWSUME_PROFILE takes precedence over AWS_PROFILE)
__prompt_aws() {
    local profile="${AWSUME_PROFILE:-$AWS_PROFILE}"
    [[ -n "$profile" ]] || return
    echo "  ${profile}"
}

# Google Cloud project (only show if GSHELL_ACTIVE is set, read from config file - no gcloud CLI calls)
__prompt_gcloud() {
    # Only show gcloud info if gshell is active
    [[ -n "${GSHELL_ACTIVE:-}" ]] || return
    
    # Try env vars first
    local project="${CLOUDSDK_CORE_PROJECT:-${GCLOUD_PROJECT:-${GOOGLE_CLOUD_PROJECT:-}}}"
    
    # If no env var, read from gcloud config file
    if [[ -z "$project" && -n "${CLOUDSDK_CONFIG:-}" ]]; then
        # Read active config name
        local active_config
        active_config=$(cat "$CLOUDSDK_CONFIG/active_config" 2>/dev/null)
        if [[ -n "$active_config" ]]; then
            # Read project from the active configuration file
            project=$(grep -E '^project\s*=' "$CLOUDSDK_CONFIG/configurations/config_$active_config" 2>/dev/null | sed -E 's/^[^=]+=\s*//' | tr -d '[:space:]')
        fi
    fi
    
    [[ -n "$project" && "$project" != "(unset)" ]] || return
    echo "  ☁ ${project}"
}

# Kubernetes context (only if KUBECONFIG is set)
__prompt_k8s() {
    [[ -n "$KUBECONFIG" ]] || return
    command -v kubectl &>/dev/null || return
    local ctx
    ctx=$(kubectl config current-context 2>/dev/null) || return
    echo "  ⎈ ${ctx}"
}

# Build prompt
__prompt_command() {
    local exit_code=$?
    local prompt_char="₿"

    if (( exit_code == 0 )); then
        local char_color="$__prompt_orange"
    else
        local char_color="$__prompt_red"
    fi

    PS1="\n${__prompt_green}$(__prompt_dir)${__prompt_reset}"
    PS1+="${__prompt_pink}$(__prompt_git)${__prompt_reset}"
    PS1+="${__prompt_mustard}$(__prompt_aws)${__prompt_reset}"
    PS1+="${__prompt_blue}$(__prompt_gcloud)${__prompt_reset}"
    PS1+="${__prompt_purple}$(__prompt_k8s)${__prompt_reset}"
    PS1+="\n${char_color}${prompt_char}${__prompt_reset} "
}

PROMPT_COMMAND=__prompt_command
