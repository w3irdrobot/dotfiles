# Dracula Theme for Mako
# https://draculatheme.com/mako

# Global defaults
font=Sans 12
background-color=#282a36
text-color=#44475a
border-color=#282a36
border-size=2
border-radius=4
default-timeout=5000
# newest notifications at the top
sort=-time
padding=8

# Urgency-specific styling
[urgency=low]
border-color=#282a36

[urgency=normal]
border-color=#f1fa8c

[urgency=critical]
border-color=#ff5555
