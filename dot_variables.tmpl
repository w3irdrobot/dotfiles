# shellcheck shell=bash

# terminal colors and language
export CLICOLOR=1
export TERM=xterm-256color
export LS_COLORS="ln=38;5;36:di=38;5;220:ex=38;5;10:so=38;5;12:*.txt=38;5;15:*.md=38;5;15:*.json=38;5;15:*.conf=38;5;15:*.py=38;5;45:*.sh=38;5;45:*.js=38;5;45:*.rs=38;5;45:*.go=38;5;45:*.jpg=38;5;13:*.jpeg=38;5;13:*.png=38;5;13:*.gif=38;5;13:*.webp=38;5;13:*.zip=38;5;13:*.tar=38;5;13:*.gz=38;5;13:*.xz=38;5;13:*.bz2=38;5;13:*.7z=38;5;13:*.deb=38;5;13:*.rpm=38;5;13"
export LANG="en_US.UTF-8"
export HISTCONTROL=ignoreboth

# terminal editor and configs
export EDITOR="codium --wait"
export XDG_CONFIG_HOME="${HOME}/.config"

{{ if eq .chezmoi.os "darwin" -}}
# Homebrew
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_ENV_HINTS=1
eval "$(/opt/homebrew/bin/brew shellenv)"

# Initial path (macOS)
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin"
{{ else -}}
# Initial path (Linux)
export PATH="/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin"
{{ end -}}

# Gnupg
GPG_TTY=$(tty)
export GPG_TTY

{{ if eq .chezmoi.os "linux" -}}
# OpenSSH (Linux)
export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"
{{ end -}}

# rust / cargo
export CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse
export PATH="${HOME}/.cargo/bin:${PATH}"

# nodejs / npm
export npm_config_prefix="$HOME/.local"

{{ if .install_nvm -}}
# nvm
export NVM_DIR="${HOME}/.nvm"
{{ end -}}

# Docker
export DOCKER_BUILDKIT=1

{{ if and (eq .chezmoi.os "linux") .install_gcloud -}}
# Google Cloud SDK
if [[ -d "${HOME}/google-cloud-sdk/bin" ]]; then
    export PATH="${HOME}/google-cloud-sdk/bin:${PATH}"
fi
{{ end -}}

# Custom scripts and such
export PATH="${HOME}/.local/bin:${PATH}"

# Default browser
{{ if eq .chezmoi.os "darwin" -}}
export BROWSER="/Applications/Brave Browser.app/Contents/MacOS/Brave Browser"
{{ else -}}
export BROWSER="/usr/bin/brave"
{{ end -}}
