{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# Brewfile hash: {{ include ".chezmoitemplates/Brewfile" | sha256sum }}

echo "Installing packages from Brewfile..."
eval "$(/opt/homebrew/bin/brew shellenv)"
brew bundle --file="{{ joinPath .chezmoi.homeDir ".config/brewfile/Brewfile" }}"
echo "Packages installed"


# Install Rust via rustup
if ! command -v rustup &> /dev/null; then
    echo "Installing rustup and Rust stable toolchain..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
fi
source "${HOME}/.cargo/env"

# Install Rust tooling
echo "Installing Rust tooling..."
cargo install cargo-binstall || true
cargo binstall -y cargo-generate \
    cargo-outdated \
    cargo-nextest \
    cargo-release
echo "Rust tooling installed"

{{ if .install_nvm -}}
# Install nvm
if [[ ! -d "${HOME}/.nvm" ]]; then
    echo "Installing nvm..."
    mkdir -p "${HOME}/.nvm"
    NVM_VERSION=$(curl -fsSL https://api.github.com/repos/nvm-sh/nvm/releases/latest | grep '"tag_name"' | sed 's/.*"tag_name": *"//;s/".*//')
    curl -o- "https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_VERSION}/install.sh" | PROFILE=/dev/null bash
    echo "nvm ${NVM_VERSION} installed"
fi
{{ end -}}

{{ end -}}
