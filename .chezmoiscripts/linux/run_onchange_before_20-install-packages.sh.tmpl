{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

echo "Installing packages..."

# Base tools
yay -Syu --needed --noconfirm \
    bind \
    fwupd \
    hugo \
    jq \
    just \
    github-cli \
    man-db \
    pacman-contrib \
    procps-ng \
    unzip \
    wl-clipboard \
    zip \
    mprocs-bin

# Network
yay -Syu --needed --noconfirm \
    mullvad-vpn-bin \
    networkmanager \
    tor

# Git tools
yay -Syu --needed --noconfirm \
    git \
    difftastic \
    lazygit \
    nodejs-commitizen

# Bluetooth
yay -Syu --needed --noconfirm \
    bluez \
    bluetui

# Terminal and common tools
yay -Syu --needed --noconfirm \
    bash-completion \
    bat \
    eza \
    fd \
    fzf \
    kitty \
    ripgrep \
    zoxide

# Desktop environment (Hyprland)
yay -Syu --needed --noconfirm \
    brightnessctl \
    grim \
    hypridle \
    hyprland \
    hyprlock \
    hyprpaper \
    hyprpolkitagent \
    hyprsunset \
    mako \
    slurp \
    ttf-jetbrains-mono-nerd \
    uwsm \
    waybar \
    xdg-desktop-portal-gtk \
    xdg-desktop-portal-hyprland

# Editors
yay -Syu --needed --noconfirm \
    opencode \
    vim \
    vscodium-bin

# Install Rust via rustup
if ! command -v rustup &> /dev/null; then
    echo "Installing rustup and Rust stable toolchain..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
fi
source "${HOME}/.cargo/env"

# Install Rust tooling
echo "Installing Rust tooling..."
cargo install cargo-binstall || true
cargo binstall -y cargo-generate \
    cargo-outdated \
    cargo-nextest \
    cargo-release
echo "Rust tooling installed"

{{ if .install_nvm -}}
# Install nvm
if [[ ! -d "${HOME}/.nvm" ]]; then
    echo "Installing nvm..."
    mkdir -p "${HOME}/.nvm"
    NVM_VERSION=$(curl -fsSL https://api.github.com/repos/nvm-sh/nvm/releases/latest | grep '"tag_name"' | sed 's/.*"tag_name": *"//;s/".*//')
    curl -o- "https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_VERSION}/install.sh" | PROFILE=/dev/null bash
    echo "nvm ${NVM_VERSION} installed"
fi
{{ end -}}

# Docker
yay -Syu --needed --noconfirm \
    docker \
    docker-compose \
    lazydocker

{{ if .install_kubernetes_tools -}}
# Kubernetes tools
yay -Syu --needed --noconfirm \
    kubectl \
    k9s
{{ end -}}

{{ if .install_gcloud -}}
# Google Cloud SDK
if ! command -v gcloud &> /dev/null; then
    echo "Installing Google Cloud SDK..."
    curl -O https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-cli-linux-x86_64.tar.gz
    tar -xf google-cloud-cli-linux-x86_64.tar.gz -C "${HOME}"
    "${HOME}/google-cloud-sdk/install.sh" --quiet --path-update false --command-completion false
    rm -f google-cloud-cli-linux-x86_64.tar.gz
    echo "Google Cloud SDK installed"
fi
{{ end -}}

# GUI apps
yay -Syu --needed --noconfirm \
    bitwarden-bin \
    brave-bin \
    chromium \
    discord \
    signal-desktop \
    spotify-launcher \
    standardnotes-bin \
    telegram-desktop \
    thunderbird \
    torbrowser-launcher

echo "Packages installed"

{{ end -}}
