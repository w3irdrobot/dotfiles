#!/usr/bin/env bash
set -euo pipefail

# secrets-import: Import GPG and SSH keys from an encrypted archive on removable media

die() {
    echo "Error: $1" >&2
    exit 1
}

check_deps() {
    local missing=()
    for cmd in gpg fzf tar; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done

    # jq only required on Linux for lsblk parsing
    if [[ "$(uname -s)" == "Linux" ]]; then
        command -v jq &>/dev/null || missing+=("jq")
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        die "Missing required tools: ${missing[*]}"
    fi
}

list_removable_media() {
    # Output: "LABEL (SIZE) - MOUNTPOINT" per line
    case "$(uname -s)" in
        Linux)
            list_removable_media_linux
            ;;
        Darwin)
            list_removable_media_macos
            ;;
        *)
            die "Unsupported operating system"
            ;;
    esac
}

list_removable_media_linux() {
    # Parse lsblk JSON, filter for removable/hotplug devices mounted under /media or /run/media
    lsblk -o MOUNTPOINT,LABEL,SIZE,HOTPLUG,RM -J 2>/dev/null | jq -r '
        .blockdevices[]
        | .. | objects
        | select(.mountpoint != null)
        | select(.mountpoint | test("^/(media|run/media)/"))
        | select(.hotplug == true or .rm == true)
        | "\(.label // "Unlabeled") (\(.size)) - \(.mountpoint)"
    ' 2>/dev/null
}

list_removable_media_macos() {
    # List /Volumes/*, excluding the boot volume
    local boot_volume
    boot_volume=$(df / | tail -1 | awk '{print $NF}')

    for vol in /Volumes/*; do
        [[ ! -d "$vol" ]] && continue
        [[ "$vol" == "$boot_volume" ]] && continue
        # Skip Time Machine snapshots and system volumes
        [[ "$vol" == "/Volumes/Macintosh HD"* ]] && continue
        [[ "$vol" == "/Volumes/Recovery"* ]] && continue

        local label size
        label=$(basename "$vol")
        size=$(df -h "$vol" 2>/dev/null | tail -1 | awk '{print $2}')
        echo "$label ($size) - $vol"
    done
}

extract_mountpoint() {
    # Extract mountpoint from "LABEL (SIZE) - MOUNTPOINT" format
    echo "$1" | sed 's/.*- //'
}

list_archives() {
    local mount_point="$1"
    # List .tar.gz.gpg files, showing just the filename
    find "$mount_point" -maxdepth 1 -name '*.tar.gz.gpg' -type f -exec basename {} \; 2>/dev/null | sort -r
}

get_current_trust_level() {
    # Get current trust level for a key (returns: ultimate, full, marginal, never, unknown, or empty)
    local keyid="$1"
    gpg --list-keys --with-colons "$keyid" 2>/dev/null | awk -F: '/^pub/ {print $2}' | head -1
}

trust_level_name() {
    # Convert trust code to human-readable name
    case "$1" in
        u) echo "ultimate" ;;
        f) echo "full" ;;
        m) echo "marginal" ;;
        n) echo "never" ;;
        *) echo "unknown" ;;
    esac
}

prompt_trust_level() {
    local keyid="$1"
    local email="$2"

    # Check current trust level
    local current_trust
    current_trust=$(get_current_trust_level "$keyid")

    if [[ "$current_trust" == "u" || "$current_trust" == "f" ]]; then
        echo "  Trust level already set to $(trust_level_name "$current_trust"), skipping."
        return 0
    fi

    echo ""
    echo "Set trust level for: $email ($keyid)"
    echo "  1 = I don't know or won't say"
    echo "  2 = I do NOT trust"
    echo "  3 = I trust marginally"
    echo "  4 = I trust fully"
    echo "  5 = I trust ultimately"
    echo "  s = skip (don't set trust)"
    echo ""

    local choice
    while true; do
        read -rp "Your choice: " choice
        case "$choice" in
            [1-5])
                # Apply trust level using gpg --import-ownertrust
                # Format: KEYID:TRUST_LEVEL:
                # Trust levels: 2=unknown, 3=never, 4=marginal, 5=full, 6=ultimate
                local gpg_trust_level=$((choice + 1))
                echo "${keyid}:${gpg_trust_level}:" | gpg --import-ownertrust &>/dev/null
                echo "Trust level set."
                break
                ;;
            [sS])
                echo "Skipping trust configuration."
                break
                ;;
            *)
                echo "Invalid choice. Please enter 1-5 or 's' to skip."
                ;;
        esac
    done
}

import_ssh_key() {
    local src="$1"
    local dest="$2"
    local keyname
    keyname=$(basename "$dest")

    # Determine permissions: 600 for private keys, 644 for public keys
    local perms="600"
    if [[ "$keyname" == *.pub ]]; then
        perms="644"
    fi

    if [[ ! -f "$dest" ]]; then
        # Key doesn't exist, copy it
        cp "$src" "$dest"
        chmod "$perms" "$dest"
        echo "  Imported: $keyname"
        return 0
    fi

    # Key exists, compare
    if cmp -s "$src" "$dest"; then
        # Identical, skip
        echo "  Skipped: $keyname (already exists, identical)"
        return 1
    else
        # Different, warn and skip
        echo "  Warning: $keyname exists and differs, skipping"
        return 2
    fi
}

import_ssh_config() {
    local src="$1"
    local dest="$HOME/.ssh/config"
    local hosts_imported=0
    local hosts_skipped=0

    if [[ ! -f "$src" ]]; then
        return 0
    fi

    # Ensure ~/.ssh/config exists
    if [[ ! -f "$dest" ]]; then
        cp "$src" "$dest"
        chmod 600 "$dest"
        # Count hosts in imported config
        hosts_imported=$(grep -cE '^Host\s+' "$src" | grep -v '\*' || echo 0)
        echo "  Created ~/.ssh/config with imported content"
        echo "$hosts_imported"
        return 0
    fi

    # Config exists - merge host blocks
    # Extract hosts from source config (skip global/wildcard)
    local src_hosts
    src_hosts=$(grep -E '^Host\s+' "$src" | awk '{print $2}' | grep -v '\*' || true)

    if [[ -z "$src_hosts" ]]; then
        echo "  No host blocks found in archive's ssh_config"
        echo "0"
        return 0
    fi

    # Check each host block
    while IFS= read -r host; do
        [[ -z "$host" ]] && continue

        # Check if host already exists in destination
        if grep -qE "^Host\\s+${host}\\s*$" "$dest"; then
            echo "  Warning: SSH config host '$host' already exists, skipping"
            hosts_skipped=$((hosts_skipped + 1))
        else
            # Append host block to destination
            echo "" >> "$dest"
            awk -v host="$host" '
                /^Host\s+/ {
                    if ($2 == host) { capture = 1 }
                    else if (capture) { exit }
                }
                capture { print }
            ' "$src" >> "$dest"
            echo "  Imported SSH config: $host"
            hosts_imported=$((hosts_imported + 1))
        fi
    done <<< "$src_hosts"

    echo "$hosts_imported:$hosts_skipped"
}

cleanup() {
    if [[ -n "${TEMP_DIR:-}" && -d "$TEMP_DIR" ]]; then
        rm -rf "$TEMP_DIR"
    fi
}

main() {
    check_deps

    # Select removable media or fall back to current directory
    local media_list mount_point
    media_list=$(list_removable_media)
    if [[ -z "$media_list" ]]; then
        echo ""
        echo "No removable media found. Looking in current directory."
        mount_point="$(pwd)"
    else
        local selected_media
        selected_media=$(echo "$media_list" | \
            fzf --prompt="Select source media: " \
                --header="Removable Media" \
                --height=40% \
                --reverse) || die "No media selected. Aborting."

        mount_point=$(extract_mountpoint "$selected_media")

        if [[ ! -d "$mount_point" || ! -r "$mount_point" ]]; then
            die "Cannot read from $mount_point"
        fi
    fi

    # List and select archive
    local archives
    archives=$(list_archives "$mount_point")
    if [[ -z "$archives" ]]; then
        die "No secret archives (.tar.gz.gpg) found on $mount_point"
    fi

    local selected_archive
    selected_archive=$(echo "$archives" | \
        fzf --prompt="Select archive to import: " \
            --header="Secret Archives" \
            --height=40% \
            --reverse) || die "No archive selected. Aborting."

    local archive_path="$mount_point/$selected_archive"

    # Create temp directory with cleanup trap
    TEMP_DIR=$(mktemp -d)
    trap cleanup EXIT

    echo ""
    echo "Decrypting archive..."
    echo "You will be prompted for the archive passphrase."
    echo ""

    # Decrypt and extract
    gpg --decrypt "$archive_path" 2>/dev/null | tar xzf - -C "$TEMP_DIR"

    echo "Archive decrypted successfully."
    echo ""

    # Import GPG keys
    local gpg_count=0
    echo "Importing GPG keys..."
    for keyfile in "$TEMP_DIR"/gpg_*.asc; do
        [[ ! -f "$keyfile" ]] && continue

        # Extract keyid from filename (gpg_KEYID.asc)
        local keyid
        keyid=$(basename "$keyfile" | sed 's/^gpg_//; s/\.asc$//')

        echo "  Importing GPG key: $keyid"
        gpg --import "$keyfile" 2>&1 | grep -E "^gpg:" | head -3

        # Get email for this key (compatible with both GNU and BSD grep)
        local email
        email=$(gpg --list-keys "$keyid" 2>/dev/null | sed -n 's/.*<\([^>]*\)>.*/\1/p' | head -1)
        [[ -z "$email" ]] && email="unknown"

        prompt_trust_level "$keyid" "$email"
        gpg_count=$((gpg_count + 1))
        echo ""
    done

    if [[ $gpg_count -eq 0 ]]; then
        echo "  No GPG keys found in archive."
    fi

    # Import SSH keys
    local ssh_imported=0
    local ssh_skipped=0
    echo ""
    echo "Importing SSH keys..."

    # Ensure ~/.ssh exists with correct permissions
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"

    for keyfile in "$TEMP_DIR"/id_*; do
        [[ ! -f "$keyfile" ]] && continue

        local keyname
        keyname=$(basename "$keyfile")
        local dest="$HOME/.ssh/$keyname"

        if import_ssh_key "$keyfile" "$dest"; then
            ssh_imported=$((ssh_imported + 1))
        else
            ssh_skipped=$((ssh_skipped + 1))
        fi
    done

    if [[ $ssh_imported -eq 0 && $ssh_skipped -eq 0 ]]; then
        echo "  No SSH keys found in archive."
    fi

    # Import SSH config
    local ssh_config_imported=0
    local ssh_config_skipped=0
    echo ""
    echo "Importing SSH config..."

    if [[ -f "$TEMP_DIR/ssh_config" ]]; then
        local config_result
        config_result=$(import_ssh_config "$TEMP_DIR/ssh_config")
        if [[ "$config_result" == *:* ]]; then
            ssh_config_imported=$(echo "$config_result" | cut -d: -f1)
            ssh_config_skipped=$(echo "$config_result" | cut -d: -f2)
        else
            ssh_config_imported=${config_result:-0}
        fi
    else
        echo "  No SSH config found in archive."
    fi

    # Summary
    echo ""
    echo "Import complete:"
    echo "  - $gpg_count GPG key(s) imported"
    echo "  - $ssh_imported SSH key(s) imported"
    if [[ $ssh_skipped -gt 0 ]]; then
        echo "  - $ssh_skipped SSH key(s) skipped (already exist or differ)"
    fi
    if [[ $ssh_config_imported -gt 0 || $ssh_config_skipped -gt 0 ]]; then
        echo "  - $ssh_config_imported SSH config host(s) imported"
        if [[ $ssh_config_skipped -gt 0 ]]; then
            echo "  - $ssh_config_skipped SSH config host(s) skipped (already exist)"
        fi
    fi
}

main "$@"
