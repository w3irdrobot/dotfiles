#!/usr/bin/env bash
set -euo pipefail

# secrets-export: Export GPG and SSH keys to an encrypted archive on removable media

die() {
    echo "Error: $1" >&2
    exit 1
}

check_deps() {
    local missing=()
    for cmd in gpg fzf tar; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done

    # jq only required on Linux for lsblk parsing
    if [[ "$(uname -s)" == "Linux" ]]; then
        command -v jq &>/dev/null || missing+=("jq")
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        die "Missing required tools: ${missing[*]}"
    fi
}

list_gpg_keys() {
    # Output: "email|KEYID" per line
    gpg --list-secret-keys --with-colons --fixed-list-mode 2>/dev/null | \
        awk -F: '
            /^sec/ { key = $5 }
            /^uid/ && key {
                match($10, /<([^>]+)>/, arr)
                if (arr[1]) {
                    print arr[1] "|" key
                    key = ""
                }
            }
        ' | sort -u
}

list_ssh_config_hosts() {
    # Output: host names from ~/.ssh/config, excluding wildcard hosts like "Host *"
    local config_file="$HOME/.ssh/config"
    if [[ -f "$config_file" ]]; then
        grep -E '^Host\s+' "$config_file" | awk '{print $2}' | grep -v '\*' | sort
    fi
}

extract_ssh_config_global() {
    # Extract the global config (everything before the first non-wildcard Host line)
    local config_file="$HOME/.ssh/config"
    awk '
        /^Host\s+/ && !/^Host\s+\*/ { exit }
        { print }
    ' "$config_file"
}

extract_ssh_config_host() {
    # Extract a single host block from ssh config
    local host="$1"
    local config_file="$HOME/.ssh/config"
    awk -v host="$host" '
        /^Host\s+/ {
            if ($2 == host) { capture = 1 }
            else if (capture) { exit }
        }
        capture { print }
    ' "$config_file"
}

get_identity_file_for_host() {
    # Extract IdentityFile path from a host block, expand ~ to $HOME
    local host="$1"
    local identity_file
    identity_file=$(extract_ssh_config_host "$host" | grep -i '^\s*IdentityFile' | awk '{print $2}' | head -1)
    # Expand ~ to $HOME
    echo "${identity_file/#\~/$HOME}"
}

list_removable_media() {
    # Output: "LABEL (SIZE) - MOUNTPOINT" per line
    case "$(uname -s)" in
        Linux)
            list_removable_media_linux
            ;;
        Darwin)
            list_removable_media_macos
            ;;
        *)
            die "Unsupported operating system"
            ;;
    esac
}

list_removable_media_linux() {
    # Parse lsblk JSON, filter for removable/hotplug devices mounted under /media or /run/media
    lsblk -o MOUNTPOINT,LABEL,SIZE,HOTPLUG,RM -J 2>/dev/null | jq -r '
        .blockdevices[]
        | .. | objects
        | select(.mountpoint != null)
        | select(.mountpoint | test("^/(media|run/media)/"))
        | select(.hotplug == true or .rm == true)
        | "\(.label // "Unlabeled") (\(.size)) - \(.mountpoint)"
    ' 2>/dev/null
}

list_removable_media_macos() {
    # List /Volumes/*, excluding the boot volume
    local boot_volume
    boot_volume=$(df / | tail -1 | awk '{print $NF}')

    for vol in /Volumes/*; do
        [[ ! -d "$vol" ]] && continue
        [[ "$vol" == "$boot_volume" ]] && continue
        # Skip Time Machine snapshots and system volumes
        [[ "$vol" == "/Volumes/Macintosh HD"* ]] && continue
        [[ "$vol" == "/Volumes/Recovery"* ]] && continue

        local label size
        label=$(basename "$vol")
        size=$(df -h "$vol" 2>/dev/null | tail -1 | awk '{print $2}')
        echo "$label ($size) - $vol"
    done
}

extract_mountpoint() {
    # Extract mountpoint from "LABEL (SIZE) - MOUNTPOINT" format
    echo "$1" | sed 's/.*- //'
}

cleanup() {
    if [[ -n "${TEMP_DIR:-}" && -d "$TEMP_DIR" ]]; then
        rm -rf "$TEMP_DIR"
    fi
}

main() {
    check_deps

    # Select GPG keys
    local gpg_keys_raw selected_gpg_keys=()
    gpg_keys_raw=$(list_gpg_keys)
    if [[ -n "$gpg_keys_raw" ]]; then
        local gpg_selection
        gpg_selection=$(echo "$gpg_keys_raw" | \
            fzf --multi \
                --prompt="Select GPG keys to export (TAB to select, ENTER to confirm): " \
                --header="GPG Secret Keys" \
                --height=40% \
                --reverse) || true
        if [[ -n "$gpg_selection" ]]; then
            while IFS= read -r line; do
                selected_gpg_keys+=("$line")
            done <<< "$gpg_selection"
        fi
    else
        echo "No GPG secret keys found."
    fi

    # Select SSH config hosts
    local ssh_hosts_raw selected_ssh_hosts=()
    ssh_hosts_raw=$(list_ssh_config_hosts)
    if [[ -n "$ssh_hosts_raw" ]]; then
        local ssh_hosts_selection
        ssh_hosts_selection=$(echo "$ssh_hosts_raw" | \
            fzf --multi \
                --prompt="Select SSH config hosts to export (TAB to select, ENTER to confirm): " \
                --header="SSH Config Hosts (keys auto-included, global config always included)" \
                --height=40% \
                --reverse) || true
        if [[ -n "$ssh_hosts_selection" ]]; then
            while IFS= read -r line; do
                selected_ssh_hosts+=("$line")
            done <<< "$ssh_hosts_selection"
        fi
    else
        echo "No SSH config hosts found in ~/.ssh/config"
    fi

    # Derive SSH keys from selected hosts
    declare -A ssh_keys_map  # Use associative array to dedupe
    for host in "${selected_ssh_hosts[@]}"; do
        local identity_file
        identity_file=$(get_identity_file_for_host "$host")
        if [[ -n "$identity_file" && -f "$identity_file" ]]; then
            ssh_keys_map["$identity_file"]=1
        fi
    done
    local selected_ssh_keys=("${!ssh_keys_map[@]}")

    # Check if anything was selected
    if [[ ${#selected_gpg_keys[@]} -eq 0 && ${#selected_ssh_hosts[@]} -eq 0 ]]; then
        die "Nothing selected. Aborting."
    fi

    echo ""
    echo "Selected ${#selected_gpg_keys[@]} GPG key(s) and ${#selected_ssh_hosts[@]} SSH config host(s) (${#selected_ssh_keys[@]} unique SSH key(s))."

    # Select removable media or fall back to current directory
    local media_list mount_point
    media_list=$(list_removable_media)
    if [[ -z "$media_list" ]]; then
        echo ""
        echo "No removable media found. Saving to current directory."
        mount_point="$(pwd)"
    else
        local selected_media
        selected_media=$(echo "$media_list" | \
            fzf --prompt="Select destination media: " \
                --header="Removable Media" \
                --height=40% \
                --reverse) || die "No media selected. Aborting."

        mount_point=$(extract_mountpoint "$selected_media")

        if [[ ! -d "$mount_point" || ! -w "$mount_point" ]]; then
            die "Cannot write to $mount_point"
        fi
    fi

    # Check for existing archive
    local archive_name archive_path
    archive_name="secrets-$(date +%Y-%m-%d).tar.gz.gpg"
    archive_path="$mount_point/$archive_name"

    if [[ -f "$archive_path" ]]; then
        echo ""
        read -rp "Archive $archive_name already exists. Overwrite? [y/N] " confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            die "Aborted by user."
        fi
    fi

    # Create temp directory with cleanup trap
    TEMP_DIR=$(mktemp -d)
    trap cleanup EXIT

    echo ""
    echo "Exporting keys..."

    # Export GPG keys
    for entry in "${selected_gpg_keys[@]}"; do
        local email keyid
        email=$(echo "$entry" | cut -d'|' -f1)
        keyid=$(echo "$entry" | cut -d'|' -f2)
        echo "  GPG: $email ($keyid)"
        gpg --export-secret-keys --armor "$keyid" > "$TEMP_DIR/gpg_${keyid}.asc"
    done

    # Copy SSH keys (derived from selected hosts)
    for keypath in "${selected_ssh_keys[@]}"; do
        local keyname
        keyname=$(basename "$keypath")
        echo "  SSH key: $keyname"
        cp "$keypath" "$TEMP_DIR/"
        # Also copy public key if it exists
        if [[ -f "${keypath}.pub" ]]; then
            cp "${keypath}.pub" "$TEMP_DIR/"
        fi
    done

    # Export SSH config (global + selected hosts)
    if [[ ${#selected_ssh_hosts[@]} -gt 0 ]]; then
        local ssh_config_file="$TEMP_DIR/ssh_config"
        # Start with global config
        extract_ssh_config_global > "$ssh_config_file"
        # Append selected host blocks
        for host in "${selected_ssh_hosts[@]}"; do
            echo "  SSH config: $host"
            echo "" >> "$ssh_config_file"
            extract_ssh_config_host "$host" >> "$ssh_config_file"
        done
    fi

    # Create encrypted archive
    echo ""
    echo "Creating encrypted archive..."
    echo "You will be prompted for a passphrase to encrypt the archive."
    echo ""

    tar czf - -C "$TEMP_DIR" . | gpg --symmetric --cipher-algo AES256 -o "$archive_path"

    echo ""
    echo "Successfully exported to: $archive_path"
    echo ""
    echo "Contents:"
    echo "  - ${#selected_gpg_keys[@]} GPG key(s)"
    echo "  - ${#selected_ssh_keys[@]} SSH key(s)"
    if [[ ${#selected_ssh_hosts[@]} -gt 0 ]]; then
        echo "  - ${#selected_ssh_hosts[@]} SSH config host(s) (+ global config)"
    fi
}

main "$@"
